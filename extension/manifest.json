{
  "manifest_version": 3,
  "name": "Redline Usage Bridge",
  "version": "0.1.0",
  "description": "Reads your Claude plan-usage limits from claude.ai and forwards them to the local Redline daemon. No data leaves your machine.",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://claude.ai/*", "http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": { "default_title": "Redline Usage Bridge", "default_popup": "popup.html" },
  "browser_specific_settings": {
    "gecko": { "id": "redline-usage-bridge@jagajaga.github.io", "strict_min_version": "115.0" }
  }
}
